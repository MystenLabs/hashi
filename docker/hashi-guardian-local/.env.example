# Copy to `.env` (docker compose auto-loads it). All values have defaults in
# compose.yaml, so `.env` is optional — override only what you need.

# Rate-limit policy supplied to the guardian at `make bootstrap`.
HASHI_REFILL_RATE_SATS_PER_SEC=100000
HASHI_MAX_BUCKET_CAPACITY_SATS=1000000000
BITCOIN_NETWORK=signet

# Only needed if the devnet you point at pinned `guardian_btc_public_key`. The
# secret must derive that exact pubkey. Generate with `make gen-master-key`
# (and pin the printed pubkey on-chain at publish time).
HASHI_MASTER_SECRET_HEX=

RUST_LOG=info
